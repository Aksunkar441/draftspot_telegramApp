BOT_TOKEN=replace-with-telegram-bot-token
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres
WEBHOOK_BASE_URL=https://your-backend-domain.com
MINI_APP_URL=https://your-frontend-domain.com
WEBHOOK_PATH=/bot/webhook
DEFAULT_CITY=Тараз
INIT_DATA_MAX_AGE_SECONDS=86400
CORS_ORIGIN_REGEX=

# Local API-only development can set SERVERLESS=true so the backend does not
# call Telegram setWebhook on startup. Render services should keep false.
SERVERLESS=false
